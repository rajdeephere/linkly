# ── Linkly — copy to .env and fill in. NEVER commit the real .env ──

# ---------- Postgres (metadata) ----------
POSTGRES_URL=jdbc:postgresql://localhost:5433/linkly
POSTGRES_USER=linkly
POSTGRES_PASSWORD=linkly

# ---------- Redis (cache / KGS pool / rate limits) ----------
REDIS_URL=redis://localhost:6379

# ---------- ClickHouse (click analytics) ----------
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=linkly
CLICKHOUSE_PASSWORD=linkly
CLICKHOUSE_DB=linkly

# ---------- Kafka (click-event stream) ----------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ---------- Auth ----------
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY_MINUTES=60

# ---------- Short-code / resolve ----------
CODE_ALPHABET=0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ
CODE_LENGTH=7
DEFAULT_DOMAIN=linkly.local
REDIRECT_MODE=302

# ---------- Abuse defense ----------
SAFE_BROWSING_API_KEY=

# ---------- Edge (Cloudflare Workers / Vercel Edge) ----------
EDGE_KV_NAMESPACE=
EDGE_PURGE_TOKEN=
